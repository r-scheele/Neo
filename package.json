{
  "name": "neo",
  "version": "1.0.0",
  "description": "Neo multi-app monorepo.",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/r-scheele/Neo.git"
  },
  "bugs": {
    "url": "https://github.com/r-scheele/Neo/issues"
  },
  "homepage": "https://github.com/r-scheele/Neo#readme",
  "scripts": {
    "dev:mobile": "npm --workspace apps/mobile run start",
    "dev:marketing": "npm --workspace apps/marketing run dev",
    "dev:web": "npm --workspace apps/web run dev",
    "mobile:android": "npm --workspace apps/mobile run android",
    "mobile:ios": "npm --workspace apps/mobile run ios",
    "mobile:web": "npm --workspace apps/mobile run web",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "overrides": {
    "lightningcss": "1.30.1",
    "jayson": {
      "uuid": "11.1.1"
    },
    "xcode": {
      "uuid": "11.1.1"
    }
  }
}
